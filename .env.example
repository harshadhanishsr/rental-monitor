# ── TELEGRAM (recommended — free) ────────────────────────────
# Create a bot: https://t.me/BotFather → /newbot
# Get your chat ID: send a message to your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── TRAVEL TIME APIs (both free, no credit card) ──────────────
# Ola Maps: https://maps.olacabs.com → sign up → create project
OLA_MAPS_API_KEY=your_ola_maps_api_key_here
# OpenRouteService: https://openrouteservice.org → sign up → request token
ORS_API_KEY=your_ors_api_key_here

# ── YOUR OFFICE LOCATION (kept private, not in config.py) ─────
OFFICE_LAT=13.0827
OFFICE_LNG=80.2707

# ── DATABASE (optional override) ─────────────────────────────
DB_PATH=data/rental_monitor.db
